# Prism Configuration
# Go backend + Ant Design frontend
# Copy this file to .env and edit values as needed: cp .env.example .env

# Server
HOST=0.0.0.0
PORT=8080
PROXY_API_KEY=change-me-before-deploy

# Storage
STORAGE_DB_DIR=
STORAGE_DB_FILE=

# OpenAI OAuth / Codex backend
OPENAI_BASE_URL=https://chatgpt.com/backend-api
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_AUTH_ENDPOINT=https://auth.openai.com/oauth/authorize
OPENAI_OAUTH_TOKEN_ENDPOINT=https://auth.openai.com/oauth/token

# Runtime defaults
DEFAULT_MODEL=gpt-5.4
DEFAULT_REASONING_EFFORT=medium
INJECT_DESKTOP_CONTEXT=false
SUPPRESS_DESKTOP_DIRECTIVES=false
REFRESH_MARGIN=5m
REFRESH_CONCURRENCY=2
REQUEST_INTERVAL_MS=50
MAX_CONCURRENT_PER_ACCOUNT=3
TIER_PRIORITY=
SESSION_TTL=12h

# Audit logging
# These logs can contain prompts, responses, headers, and account metadata.
CURSOR_AUDIT_LOG_ENABLED=false
OPENAI_EGRESS_AUDIT_LOG_ENABLED=false
CUSTOM_EGRESS_AUDIT_LOG_ENABLED=false
